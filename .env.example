# Environment variables — copy this file to .env and fill in your values
# NEVER commit .env to version control

# === Database ===
POSTGRES_USER=wc_user
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=worldcup

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === App ===
ENVIRONMENT=development
SECRET_KEY=change_me_to_a_random_64_char_string

# === Sports Data APIs ===
# Free tier available at https://www.football-data.org/
FOOTBALL_DATA_API_KEY=your_football_data_api_key_here

# Free tier available at https://www.api-football.com/
API_SPORTS_KEY=your_api_sports_key_here

# Optional: StatsBomb open data (no key needed for open data)
# https://github.com/statsbomb/open-data

# === Ingestion ===
POLL_INTERVAL_SECONDS=30

# === Frontend ===
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
